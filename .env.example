# Neon Postgres (pgvector) — copy to .env and fill real values.
# Use the DIRECT (unpooled) endpoint — host WITHOUT "-pooler". The app pins
# search_path via the libpq `options` startup parameter, which Neon's pooled
# (PgBouncer) endpoint rejects ("unsupported startup parameter in options").
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Dedicated Neon "test" branch for the Vitest suite. REQUIRED before running
# tests: vitest.config.ts overrides DATABASE_URL with this so integration tests
# (which delete from photos/faces/... in setup) can NEVER touch production. Must
# be a SEPARATE branch and the DIRECT endpoint (no "-pooler"). vitest throws if
# it equals the production DATABASE_URL. See memory: shaadi-prod-wipe-incident.
TEST_DATABASE_URL=postgresql://user:pass@test-branch-host/neondb?sslmode=require

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
R2_ENDPOINT=https://YOUR_R2_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_ORIGINALS=shaadi-photos
R2_BUCKET_PREVIEWS=shaadi-previews
R2_PREVIEWS_PUBLIC_URL=https://YOUR_R2_PUBLIC_BUCKET.r2.dev

# Admin
ADMIN_PASSWORD=
# High-entropy secret for signing admin session cookies (e.g. `openssl rand -hex 32`).
# Independent of ADMIN_PASSWORD so either can be rotated on its own.
SESSION_SECRET=
